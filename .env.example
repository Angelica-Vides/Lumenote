# Supabase — https://supabase.com/dashboard → New project
#
# Settings → API:
#   VITE_SUPABASE_URL     = Project URL
#   VITE_SUPABASE_ANON_KEY = anon public key (safe for browser with RLS enabled)

VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# GitHub Actions CI only — set the same values as repo Secrets (Settings → Actions):
# VITE_SUPABASE_URL
# VITE_SUPABASE_ANON_KEY
# VITE_BASE_PATH is set automatically in .github/workflows/deploy.yml from the repo name.

# Supabase Edge Function secret, set with:
# supabase secrets set OPENAI_API_KEY=sk-...
# Optional:
# supabase secrets set OPENAI_MODEL=gpt-4o-mini
